<mxfile host="app.diagrams.net">
  <diagram name="GTD 工作流" id="gtd-workflow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 标题 -->
        <mxCell id="title" value="GTD 工作流程" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=24;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="480" y="20" width="240" height="40" as="geometry" />
        </mxCell>

        <!-- 收集 Collect -->
        <mxCell id="collect" value="收集 Collect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- 整理 Process -->
        <mxCell id="process" value="整理 Process" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="320" y="120" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- 组织 Organize -->
        <mxCell id="organize" value="组织 Organize" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="560" y="120" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- 计划 Plan -->
        <mxCell id="plan" value="计划 Plan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="800" y="120" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- 执行 DO -->
        <mxCell id="do" value="执行 Do" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1040" y="120" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- 箭头连线 -->
        <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="collect" target="process">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="process" target="organize">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="organize" target="plan">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666" edge="1" parent="1" source="plan" target="do">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 收集阶段详细说明 -->
        <mxCell id="collect_detail" value="• 收集箱 Inbox\n• 随时捕捉想法\n• 清空大脑" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- 整理阶段详细说明 -->
        <mxCell id="process_detail" value="• 是否可执行?\n• 是→下一步行动\n• 否→垃圾桶/参考资料/ someday" style="text;html=1;strokeColor=#82b366;fillColor=#d5e8d4;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="280" y="200" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- 组织阶段详细说明 -->
        <mxCell id="organize_detail" value="• 项目清单 Projects\n• 等待清单 Waiting\n• 上下文 Context\n• Someday/Maybe" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="520" y="200" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- 计划阶段详细说明 -->
        <mxCell id="plan_detail" value="• 每周回顾 Weekly Review\n• 分解项目为行动\n• 设定优先级" style="text;html=1;strokeColor=#b85450;fillColor=#f8cecc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="760" y="200" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- 执行阶段详细说明 -->
        <mxCell id="do_detail" value="• 专注当下行动\n• 使用番茄钟\n• 记录完成情况" style="text;html=1;strokeColor=#9673a6;fillColor=#e1d5e7;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="1000" y="200" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- 循环箭头 - 回顾 -->
        <mxCell id="review" value="每周回顾" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#FF6B00;dashed=1" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="1120" y="80" as="sourcePoint" />
            <mxPoint x="40" y="80" as="targetPoint" />
            <Array as="points">
              <mxPoint x="580" y="40" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 垃圾桶 -->
        <mxCell id="trash" value="🗑️ 垃圾桶" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="40" y="340" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- 参考资料 -->
        <mxCell id="reference" value="📚 参考资料" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="160" y="340" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- Someday -->
        <mxCell id="someday" value="🌙 Someday" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="280" y="340" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- 连接到整理阶段 -->
        <mxCell id="arrow_trash" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#999999;dashed=1" edge="1" parent="1" source="process" target="trash">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_ref" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#999999;dashed=1" edge="1" parent="1" source="process" target="reference">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow_someday" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#999999;dashed=1" edge="1" parent="1" source="process" target="someday">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>